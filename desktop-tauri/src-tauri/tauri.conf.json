{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "DBD Tracker Overlay",
  "version": "1.0.0",
  "identifier": "local.dbdtracker.overlay",
  "build": {
    "frontendDist": "../src"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "DBD Tracker Overlay",
        "width": 480,
        "height": 620,
        "minWidth": 420,
        "minHeight": 480,
        "decorations": false,
        "transparent": true,
        "alwaysOnTop": true,
        "resizable": true,
        "visible": false,
        "skipTaskbar": false,
        "backgroundColor": "#00000000"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
